generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String        @id @default(cuid())
  userId       String
  fullName     String
  phone        String
  email        String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  attendances  Attendance[]
  reminders    ReminderLog[]
  chatMessages ChatMessage[]
  whatsappAgentStates WhatsappAgentState[]
  waitlistEntries WaitlistEntry[]

  @@index([userId])
}

model UnknownContact {
  id          String                  @id @default(cuid())
  userId      String
  phone       String
  displayName String?
  status      String                  @default("NEW")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    UnknownContactMessage[]

  @@unique([userId, phone])
  @@index([userId])
  @@index([status])
}

model UnknownContactMessage {
  id               String         @id @default(cuid())
  userId           String
  unknownContactId String
  direction        String
  message          String
  intent           String?
  createdAt        DateTime       @default(now())
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  unknownContact   UnknownContact @relation(fields: [unknownContactId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([unknownContactId])
  @@index([createdAt])
}

model Appointment {
  id           String        @id @default(cuid())
  userId      String
  clientId    String
  clientAppointmentNumber Int?
  title       String
  startsAt    DateTime
  previousStartsAt DateTime?
  durationMin Int           @default(60)
  status      String        @default("PENDING")
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reminders   ReminderLog[]
  chatMessages ChatMessage[]
  fallbackWaitlistEntries WaitlistEntry[] @relation("WaitlistFallbackAppointment")
  whatsappAgentStates WhatsappAgentState[]

  @@index([userId])
  @@index([startsAt])
  @@index([clientId])
  @@unique([clientId, clientAppointmentNumber])
}

model WaitlistEntry {
  id                  String        @id @default(cuid())
  userId              String
  clientId            String
  title               String
  desiredDate         String
  startTime           String
  endTime             String
  durationMin         Int           @default(60)
  priority            String        @default("NORMAL")
  status              String        @default("WAITING")
  notes               String?
  offeredStartsAt     DateTime?
  offeredAt           DateTime?
  bookedAppointmentId String?
  fallbackAppointmentId String?
  clientAppointmentNumber Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client              Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fallbackAppointment Appointment? @relation("WaitlistFallbackAppointment", fields: [fallbackAppointmentId], references: [id], onDelete: SetNull)
  chatMessages        ChatMessage[]
  opportunities       WaitlistOpportunity[] @relation("WaitlistOpportunityEntry")

  @@index([userId])
  @@index([clientId])
  @@index([desiredDate])
  @@index([status])
  @@index([fallbackAppointmentId])
}

model WaitlistOpportunity {
  id                  String         @id @default(cuid())
  userId              String
  sourceAppointmentId String?
  startsAt            DateTime
  durationMin         Int
  status              String         @default("AVAILABLE")
  offeredEntryId      String?
  offeredStartsAt     DateTime?
  offeredAt           DateTime?
  bookedAppointmentId String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  offeredEntry        WaitlistEntry? @relation("WaitlistOpportunityEntry", fields: [offeredEntryId], references: [id], onDelete: SetNull)
  chatMessages        ChatMessage[]

  @@index([userId])
  @@index([startsAt])
  @@index([status])
  @@index([offeredEntryId])
}

model Notification {
  id                    String   @id @default(cuid())
  userId                String
  type                  String
  title                 String
  body                  String
  target                String?
  status                String   @default("UNREAD")
  appointmentId         String?
  waitlistEntryId       String?
  waitlistOpportunityId String?
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  date      DateTime
  status    String   @default("PRESENT")
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([clientId])
}

model ReminderLog {
  id            String         @id @default(cuid())
  userId        String
  clientId      String
  appointmentId String?
  channel       String         @default("whatsapp")
  type          String         @default("MANUAL")
  message       String
  status        String
  response      String?
  sentAt        DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sentAt])
  @@index([clientId])
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  clients      Client[]
  appointments Appointment[]
  attendances  Attendance[]
  reminders    ReminderLog[]
  chatMessages ChatMessage[]
  whatsappAgentStates WhatsappAgentState[]
  waitlistEntries WaitlistEntry[]
  waitlistOpportunities WaitlistOpportunity[]
  notifications Notification[]
  unknownContacts UnknownContact[]
  unknownContactMessages UnknownContactMessage[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ChatMessage {
  id            String       @id @default(cuid())
  userId        String
  clientId      String
  appointmentId String?
  waitlistEntryId String?
  waitlistOpportunityId String?
  direction     String
  message       String
  intent        String?
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  waitlistEntry  WaitlistEntry? @relation(fields: [waitlistEntryId], references: [id], onDelete: SetNull)
  waitlistOpportunity WaitlistOpportunity? @relation(fields: [waitlistOpportunityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@index([appointmentId])
  @@index([waitlistEntryId])
  @@index([waitlistOpportunityId])
  @@index([createdAt])
}

model WhatsappAgentState {
  id            String      @id @default(cuid())
  userId        String
  clientId      String
  appointmentId String
  topic         String      @default("REPROGRAM")
  rangeStart    String?
  rangeEnd      String?
  period        String?
  offeredSlots  Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, topic])
  @@index([userId])
  @@index([clientId])
}
